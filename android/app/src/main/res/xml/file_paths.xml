<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Scoped to an images subdirectory rather than the external/cache
         storage root (path=".") — narrows what a grantUriPermissions share
         intent can expose, even though the provider itself is not exported. -->
    <external-path name="my_images" path="images/" />
    <cache-path name="my_cache_images" path="images/" />
</paths>
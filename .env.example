# URL of the deployed /frontend app. The Capacitor shell loads this URL in a webview.
# Set at BUILD time (consumed by capacitor.config.ts before cap sync).
# Examples:
#   Android emulator pointing at host machine:  http://10.0.2.2:3000
#   iOS simulator pointing at host machine:     http://localhost:3000
#   Vercel preview:                             https://aroha-astrology-<preview>.vercel.app
#   Production:                                 https://app.arohaastrology.in
# If unset, the app shows a static "Loading…" fallback screen with no remote content.
CAPACITOR_SERVER_URL=

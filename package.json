{
  "name": "@aroha-astrology/mobile",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "cap:sync": "pnpm build && cap sync",
